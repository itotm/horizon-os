#!/bin/bash
set -oue pipefail

logger "Bash configuring for user"

if ! grep -q "# HorizonOS customizations" ~/.bashrc; then
    {
        echo ""
        echo "# HorizonOS customizations"
        echo "export PROMPT_DIR_COLOR=\"1;96\""
        echo "export MANROFFOPT=\"-c\""
        echo "export LESS_TERMCAP_mb=$'\e[01;31m'"
        echo "export LESS_TERMCAP_md=$'\e[01;33m'"
        echo "export LESS_TERMCAP_me=$'\e[0m'"
        echo "export LESS_TERMCAP_se=$'\e[0m'"
        echo "export LESS_TERMCAP_so=$'\e[01;44;37m'"
        echo "export LESS_TERMCAP_ue=$'\e[0m'"
        echo "export LESS_TERMCAP_us=$'\e[01;32m'"
        echo "bind 'set completion-ignore-case on'"
        echo "if command -v dust >/dev/null 2>&1; then alias du='dust'; fi"
        echo "if command -v mc >/dev/null 2>&1; then alias mc='mc -u'; fi"
        echo "if command -v fzf >/dev/null 2>&1; then eval \"\$(fzf --bash)\"; fi"
    } | tee -a ~/.bashrc
fi

logger "Bash configuration complete"
